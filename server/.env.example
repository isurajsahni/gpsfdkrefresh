PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://your_user:your_strong_password@cluster.mongodb.net/gpsfdk?retryWrites=true&w=majority
JWT_SECRET=generate_with_node_e_require_crypto_randomBytes_64_toString_hex

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Resend)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USER=resend
EMAIL_PASS=your_resend_api_key_here
EMAIL_FROM=your_verified_sender@domain.com

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

CLIENT_URL=http://localhost:5173

# Admin seed credentials (optional, for seed.js)
# ADMIN_EMAIL=admin@gpsfdk.com
# ADMIN_PASSWORD=your_strong_admin_password
